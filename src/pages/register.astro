---
// src/pages/register.astro
import '../styles/global.css';

let logoUrl = "/favicon.svg"; 
try {
  // El servidor de Vercel lee directo de la IP (esto está bien)
  const logoResponse = await fetch('http://51.21.220.203/api/Logo?populate=*');
  const logoJson = await logoResponse.json();
  const logoPath = logoJson.data?.logo?.url || logoJson.data?.logo?.[0]?.url;
  
  // AQUÍ ESTABA EL FALLO: Para el navegador, usamos el túnel seguro
  if (logoPath) logoUrl = `/aws${logoPath}`;
} catch (error) {
  console.error("Error conectando con Strapi:", error);
}
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href={logoUrl} />
    <meta name="viewport" content="width=device-width" />
    <title>Crear Cuenta - Folio.</title>
  </head>
  <body class="bg-gray-50 text-gray-900 font-sans antialiased min-h-screen flex flex-col">
    
    <header class="py-6 px-4 sm:px-6 lg:px-8 flex justify-center absolute w-full top-0">
      <a href="/" class="flex items-center gap-2.5 hover:opacity-80 transition">
        <div class="h-10 w-10 flex items-center justify-center overflow-hidden rounded-xl bg-white shadow-sm border border-gray-100">
          <img src={logoUrl} alt="Logo Folio" class="h-full w-full object-contain p-1" />
        </div>
        <span class="text-2xl font-extrabold tracking-tighter text-gray-950">Folio<span class="text-orange-500">.</span></span>
      </a>
    </header>

    <main class="flex-grow flex items-center justify-center px-4 pt-24 pb-12">
      <div class="bg-white w-full max-w-md p-8 sm:p-10 rounded-3xl shadow-sm border border-gray-200">
        
        <div class="text-center mb-8">
          <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">Únete a la comunidad</h1>
          <p class="text-gray-500 mt-2 text-sm">Miles de historias te están esperando.</p>
        </div>

        <form id="registerForm" class="flex flex-col gap-5">
          <div>
            <label class="block text-sm font-bold text-gray-700 mb-1.5">Nombre de usuario</label>
            <input type="text" id="username" required placeholder="Ej: guille_dev" class="w-full bg-gray-50 border border-gray-200 rounded-xl py-3 px-4 outline-none focus:ring-2 focus:ring-orange-200 focus:border-orange-500 transition shadow-inner text-sm" />
          </div>

          <div>
            <label class="block text-sm font-bold text-gray-700 mb-1.5">Correo electrónico</label>
            <input type="email" id="email" required placeholder="tu@email.com" class="w-full bg-gray-50 border border-gray-200 rounded-xl py-3 px-4 outline-none focus:ring-2 focus:ring-orange-200 focus:border-orange-500 transition shadow-inner text-sm" />
          </div>

          <div>
            <label class="block text-sm font-bold text-gray-700 mb-1.5">Contraseña</label>
            <input type="password" id="password" required placeholder="••••••••" class="w-full bg-gray-50 border border-gray-200 rounded-xl py-3 px-4 outline-none focus:ring-2 focus:ring-orange-200 focus:border-orange-500 transition shadow-inner text-sm" />
          </div>

          <button type="submit" class="w-full bg-orange-500 text-white py-3.5 mt-2 rounded-full font-bold text-md hover:bg-orange-600 transition shadow-md active:scale-95">
            Crear cuenta
          </button>
        </form>

        <p class="text-center text-sm text-gray-500 mt-8">
          ¿Ya tienes una cuenta? 
          <a href="/login" class="font-bold text-orange-500 hover:text-orange-600 transition">Inicia sesión</a>
        </p>
      </div>
    </main>

  </body>
</html>

<script>
  const registerForm = document.getElementById('registerForm');
  const submitBtn = registerForm.querySelector('button[type="submit"]');

  registerForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const originalText = submitBtn.innerHTML;
    submitBtn.innerHTML = 'Creando cuenta...';
    submitBtn.disabled = true;
    submitBtn.classList.add('opacity-70');

    const username = document.getElementById('username').value;
    const email = document.getElementById('email').value;
    const password = document.getElementById('password').value;

    try {
      const response = await fetch('/aws/api/auth/local/register', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          username: username,
          email: email,
          password: password,
        }),
      });

      // Blindaje extra para que no se rompa si Vercel devuelve un error 500 en HTML
      if (!response.ok) {
        const errorText = await response.text();
        console.error("El servidor respondió con error:", errorText);
        
        // Intentamos extraer el JSON de Strapi si existe
        try {
          const errorJson = JSON.parse(errorText);
          alert('Error al crear la cuenta: ' + (errorJson.error?.message || 'Revisa los datos.'));
        } catch (e) {
          alert('Error crítico de red. Revisa la consola F12.');
        }
        return;
      }

      const data = await response.json();

      localStorage.setItem('folio_token', data.jwt);
      localStorage.setItem('folio_user', JSON.stringify(data.user));
      
      alert('¡Cuenta creada con éxito! Bienvenido a Folio.');
      window.location.href = '/';
      
    } catch (error) {
      console.error("Error de conexión:", error);
      alert('Error de conexión con el servidor. Mira la consola para más detalles.');
    } finally {
      submitBtn.innerHTML = originalText;
      submitBtn.disabled = false;
      submitBtn.classList.remove('opacity-70');
    }
  });
</script>