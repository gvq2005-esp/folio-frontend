---
// src/pages/upload.astro
import '../styles/global.css';

let logoUrl = "/favicon.svg"; 
try {
  const logoResponse = await fetch('http://51.21.220.203/api/Logo?populate=*');
  const logoJson = await logoResponse.json();
  const logoPath = logoJson.data?.logo?.url || logoJson.data?.logo?.[0]?.url;
  if (logoPath) logoUrl = `http://aws${logoPath}`;
} catch (error) {
  console.error("Error conectando con Strapi:", error);
}

let generos = [];
try {
  const generosResponse = await fetch('http://51.21.220.203/api/generos');
  const generosJson = await generosResponse.json();
  generos = generosJson.data || [];
} catch (error) {
  console.error("Error cargando géneros:", error);
}
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href={logoUrl} />
    <meta name="viewport" content="width=device-width" />
    <title>Subir Historia - Folio.</title>
  </head>
  <body class="bg-gray-50 text-gray-900 font-sans antialiased min-h-screen flex flex-col">
    
    <header class="bg-white border-b border-gray-100 sticky top-0 z-50 shadow-sm">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-20 flex items-center justify-between gap-6">
        <a href="/" class="flex items-center gap-2.5 flex-shrink-0 hover:opacity-80 transition">
          <div class="h-12 w-12 flex items-center justify-center overflow-hidden rounded-xl bg-white shadow-sm border border-gray-100">
            <img src={logoUrl} alt="Logo Folio" class="h-full w-full object-contain p-1" />
          </div>
          <span class="text-3xl font-extrabold tracking-tighter text-gray-950">Folio<span class="text-orange-500">.</span></span>
        </a>

        <nav class="flex items-center gap-8 text-md font-medium flex-shrink-0 ml-auto">
          <div id="loggedOutMenu" class="items-center gap-8 hidden">
            <a href="/login" class="text-gray-700 hover:text-orange-600 transition">Iniciar sesión</a>
            <a href="/register" class="bg-orange-500 text-white px-8 py-3.5 rounded-full font-semibold hover:bg-orange-600 transition shadow-md active:scale-95">
              Crear cuenta
            </a>
          </div>

          <div id="loggedInMenu" class="items-center gap-6 hidden">
            <a href="/upload" class="text-orange-600 border-b-2 border-orange-500 pb-1 mr-4">Subir historia</a>
            <div class="flex items-center gap-3 cursor-pointer group">
              <div id="userAvatar" class="w-10 h-10 rounded-full bg-orange-100 text-orange-600 border border-orange-200 flex items-center justify-center font-extrabold text-sm group-hover:bg-orange-500 group-hover:text-white transition-colors">
                U
              </div>
              <span id="userName" class="font-bold text-gray-900 group-hover:text-orange-600 transition-colors">Usuario</span>
            </div>
            
            <button id="logoutBtn" class="text-sm font-semibold text-gray-400 hover:text-red-500 transition">
              Cerrar sesión
            </button>
          </div>
        </nav>
      </div>
    </header>

    <main class="flex-grow py-8 px-4 sm:px-6 opacity-0 transition-opacity duration-300" id="mainContent">
      <div class="w-full max-w-2xl mx-auto bg-white py-12 px-10 sm:px-16 md:px-20 rounded-3xl shadow-sm border border-gray-200 my-12">
        
        <div class="text-center mb-10">
          <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight pt-4">Publica tu historia</h1>
          <p class="text-gray-500 mt-2">Comparte tu mundo con miles de lectores.</p>
        </div>

        <form id="uploadForm" class="flex flex-col gap-6">
          
          <div>
            <label class="block text-sm font-bold text-gray-700 mb-2">Título de la historia *</label>
            <input type="text" name="Titulo" required placeholder="Ej: La brújula y el mapa" class="w-full bg-white border border-gray-300 rounded-xl py-3 px-4 outline-none focus:ring-2 focus:ring-orange-200 focus:border-orange-500 transition shadow-sm" />
          </div>

          <div>
            <label class="block text-sm font-bold text-gray-700 mb-2">Tu nombre de autor *</label>
            <input type="text" name="Autor" required placeholder="Ej: J.K. Rowling" class="w-full bg-white border border-gray-300 rounded-xl py-3 px-4 outline-none focus:ring-2 focus:ring-orange-200 focus:border-orange-500 transition shadow-sm" />
          </div>

          <div>
            <label class="block text-sm font-bold text-gray-700 mb-2">Género principal *</label>
            <div class="relative">
              <select name="Genero" required class="w-full bg-white border border-gray-300 rounded-xl py-3 px-4 outline-none focus:ring-2 focus:ring-orange-200 focus:border-orange-500 transition appearance-none cursor-pointer shadow-sm">
                <option value="" disabled selected>Selecciona un género...</option>
                
                {generos.map((gen) => {
                  const id = gen.id;
                  const nombre = gen.attributes ? gen.attributes.Nombre : gen.Nombre;
                  return (
                    <option value={id}>{nombre}</option>
                  )
                })}

              </select>
              <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-gray-500">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
              </div>
            </div>
          </div>

          <div>
            <label class="block text-sm font-bold text-gray-700 mb-2">Sinopsis *</label>
            <textarea name="Sinopsis" rows="4" required placeholder="De qué trata tu historia..." class="w-full bg-white border border-gray-300 rounded-xl py-3 px-4 outline-none focus:ring-2 focus:ring-orange-200 focus:border-orange-500 transition resize-none shadow-sm"></textarea>
          </div>

          <hr class="border-t border-gray-100 my-2" />

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 w-full">
            
            <div class="flex flex-col w-full">
              <span class="block text-sm font-bold text-gray-700 mb-2">Portada (Imagen)</span>
              <div class="relative w-full h-64">
                
                <label class="flex flex-col items-center justify-center w-full h-full border-2 border-dashed border-gray-300 rounded-2xl bg-gray-50 hover:bg-orange-50 hover:border-orange-400 transition cursor-pointer overflow-hidden relative">
                  <input type="file" id="coverInput" name="Portada" accept="image/png, image/jpeg, image/webp" style="position: absolute; width: 100%; height: 100%; top: 0; left: 0; opacity: 0; cursor: pointer; z-index: 10;" />
                  
                  <div id="coverPlaceholder" class="flex flex-col items-center justify-center text-center px-4 transition-opacity duration-300 pointer-events-none">
                    <svg class="w-10 h-10 mb-3 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                    <p class="text-sm font-semibold text-gray-500"><span class="text-orange-600">Sube</span> una imagen</p>
                    <p class="text-xs text-gray-400 mt-1">PNG, JPG o WEBP</p>
                  </div>

                  <img id="coverPreview" src="" alt="Previsualización" class="absolute inset-0 w-full h-full object-contain bg-gray-100 hidden pointer-events-none z-0" />
                </label>

                <button type="button" id="removeCoverBtn" class="absolute top-2 right-2 p-1.5 bg-white text-red-500 border border-red-100 rounded-full hover:bg-red-50 transition-colors shadow-sm hidden" style="z-index: 20;">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
              </div>
            </div>

            <div class="flex flex-col w-full">
              <span class="block text-sm font-bold text-gray-700 mb-2">Manuscrito (PDF) *</span>
              <div class="relative w-full h-64">
                
                <label class="flex flex-col items-center justify-center w-full h-full border-2 border-dashed border-gray-300 rounded-2xl bg-gray-50 hover:bg-orange-50 hover:border-orange-400 transition cursor-pointer overflow-hidden relative">
                  <input type="file" id="pdfInput" name="ArchivoPDF" accept="application/pdf" required style="position: absolute; width: 100%; height: 100%; top: 0; left: 0; opacity: 0; cursor: pointer; z-index: 10;" />
                  
                  <div id="pdfPlaceholder" class="flex flex-col items-center justify-center text-center px-4 transition-opacity duration-300 pointer-events-none">
                    <svg class="w-10 h-10 mb-3 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                    <p class="text-sm font-semibold text-gray-500"><span class="text-orange-600">Sube</span> tu manuscrito</p>
                    <p class="text-xs text-gray-400 mt-1">Formato PDF obligatorio</p>
                  </div>

                  <div id="pdfPreview" class="absolute inset-0 bg-white flex flex-col items-center justify-center text-center px-4 hidden pointer-events-none z-0">
                    <svg class="w-12 h-12 mb-3 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    <p id="pdfNamePreview" class="text-sm font-bold text-gray-800 truncate w-full px-6"></p>
                    <p class="text-xs text-green-600 font-semibold mt-1">Archivo listo</p>
                  </div>
                </label>

                <button type="button" id="removePdfBtn" class="absolute top-2 right-2 p-1.5 bg-white text-red-500 border border-red-100 rounded-full hover:bg-red-50 transition-colors shadow-sm hidden" style="z-index: 20;">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
              </div>
            </div>

          </div>

          <div class="pt-4">
            <button type="submit" id="submitBtn" class="w-full bg-orange-500 text-white py-4 rounded-full font-bold text-lg hover:bg-orange-600 transition shadow-md active:scale-95 flex justify-center items-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path></svg>
              Publicar Historia
            </button>
          </div>
          
        </form>
      </div>
    </main>
  </body>
</html>

<script>
  // --- 1. PROTECCIÓN DE RUTA Y AUTENTICACIÓN ---
  const token = localStorage.getItem('folio_token');
  const userString = localStorage.getItem('folio_user');

  // Si no hay token, redirigir al login y detener ejecución
  if (!token || !userString) {
    window.location.href = '/login';
  } else {
    // Si hay token, configurar el menú y mostrar la página
    const user = JSON.parse(userString);
    const loggedInMenu = document.getElementById('loggedInMenu');
    
    document.getElementById('userName').textContent = user.username;
    document.getElementById('userAvatar').textContent = user.username.charAt(0).toUpperCase();
    
    loggedInMenu.classList.remove('hidden');
    loggedInMenu.classList.add('flex');
    
    // Mostrar contenido principal (fade-in)
    document.getElementById('mainContent').classList.remove('opacity-0');

    document.getElementById('logoutBtn').addEventListener('click', () => {
      localStorage.removeItem('folio_token');
      localStorage.removeItem('folio_user');
      window.location.href = '/'; 
    });
  }

  // --- 2. LÓGICA DE PREVISUALIZACIÓN DE ARCHIVOS ---
  const coverInput = document.getElementById('coverInput');
  const coverPreview = document.getElementById('coverPreview');
  const coverPlaceholder = document.getElementById('coverPlaceholder');
  const removeCoverBtn = document.getElementById('removeCoverBtn');

  const pdfInput = document.getElementById('pdfInput');
  const pdfPreview = document.getElementById('pdfPreview');
  const pdfPlaceholder = document.getElementById('pdfPlaceholder');
  const pdfNamePreview = document.getElementById('pdfNamePreview');
  const removePdfBtn = document.getElementById('removePdfBtn');

  coverInput.addEventListener('change', (e) => {
    const file = e.target.files[0];
    if (file) {
      const reader = new FileReader();
      reader.onload = (event) => {
        coverPreview.src = event.target.result;
        coverPreview.classList.remove('hidden');
        coverPlaceholder.classList.add('opacity-0');
        removeCoverBtn.classList.remove('hidden');
      };
      reader.readAsDataURL(file);
    }
  });

  removeCoverBtn.addEventListener('click', () => {
    coverInput.value = '';
    coverPreview.classList.add('hidden');
    coverPreview.src = '';
    coverPlaceholder.classList.remove('opacity-0');
    removeCoverBtn.classList.add('hidden');
  });

  pdfInput.addEventListener('change', (e) => {
    const file = e.target.files[0];
    if (file) {
      pdfNamePreview.textContent = file.name;
      pdfPreview.classList.remove('hidden');
      pdfPlaceholder.classList.add('opacity-0');
      removePdfBtn.classList.remove('hidden');
    }
  });

  removePdfBtn.addEventListener('click', () => {
    pdfInput.value = '';
    pdfPreview.classList.add('hidden');
    pdfNamePreview.textContent = '';
    pdfPlaceholder.classList.remove('opacity-0');
    removePdfBtn.classList.add('hidden');
  });

  // --- 3. ENVÍO DE FORMULARIO A STRAPI (CON TOKEN) ---
  const form = document.getElementById('uploadForm');
  const submitBtn = document.getElementById('submitBtn');

  form.addEventListener('submit', async (e) => {
    e.preventDefault(); 

    const originalText = submitBtn.innerHTML;
    submitBtn.innerHTML = 'Subiendo...';
    submitBtn.disabled = true;
    submitBtn.classList.add('opacity-70');

    try {
      const formDataRaw = new FormData(form);
      let portadaId = null;
      let pdfId = null;

      // SUBIR IMAGEN
      const portada = formDataRaw.get('Portada');
      if (portada && portada.size > 0) {
        const coverForm = new FormData();
        coverForm.append('files', portada);
        const resCover = await fetch('http://aws/api/upload', {
          method: 'POST',
          headers: {
            'Authorization': `Bearer ${token}` // Firmamos el archivo con nuestro token
          },
          body: coverForm
        });
        if (!resCover.ok) throw new Error("Strapi rechazó la subida de la imagen");
        const dataCover = await resCover.json();
        portadaId = dataCover[0].id;
      }

      // SUBIR PDF
      const archivoPDF = formDataRaw.get('ArchivoPDF');
      if (archivoPDF && archivoPDF.size > 0) {
        const pdfForm = new FormData();
        pdfForm.append('files', archivoPDF);
        const resPdf = await fetch('http://aws/api/upload', {
          method: 'POST',
          headers: {
            'Authorization': `Bearer ${token}` // Firmamos el PDF
          },
          body: pdfForm
        });
        if (!resPdf.ok) throw new Error("Strapi rechazó la subida del PDF");
        const dataPdf = await resPdf.json();
        pdfId = dataPdf[0].id;
      }

      // PREPARAR DATOS
      const dataTextos = {
        Titulo: formDataRaw.get('Titulo'),
        Autor: formDataRaw.get('Autor'),
        Sinopsis: formDataRaw.get('Sinopsis'),
        genero: Number(formDataRaw.get('Genero')),
      };

      if (portadaId) dataTextos.Portada = portadaId;
      if (pdfId) dataTextos.PDF = pdfId; 

      const response = await fetch('http://aws/api/historias', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${token}` // Firmamos la historia
        },
        body: JSON.stringify({ data: dataTextos }),
      });

      if (response.ok) {
        alert('¡Enhorabuena! Tu historia se ha publicado correctamente.');
        window.location.href = '/'; 
      } else {
        const errorData = await response.json();
        console.error("Error al crear historia:", errorData);
        alert('Hubo un error de validación en los textos. Revisa la consola.');
      }

    } catch (error) {
      console.error("Error general:", error);
      alert('Error: ' + error.message);
    } finally {
      submitBtn.innerHTML = originalText;
      submitBtn.disabled = false;
      submitBtn.classList.remove('opacity-70');
    }
  });
</script>