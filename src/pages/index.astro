                <div class="grid grid-cols-1 md:grid-cols-4 lg:grid-cols-5 gap-12 mb-16">
                    <div class="lg:col-span-2 flex flex-col items-start">
                        <a href="/" class="flex items-center gap-2 mb-5">
                            <div class="bg-orange-500 p-1.5 rounded-lg flex items-center justify-center shadow-inner">
                                <svg class="h-5 w-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
                                </svg>
                            </div>
                            <span class="text-xl font-extrabold tracking-tighter text-gray-950">Folio<span class="text-orange-500">.</span></span>
                        </a>

                        <p class="text-gray-500 text-sm mb-6 max-w-sm leading-relaxed">
                            Un hogar para las historias. Descubre, lee y publica ficción original de escritores de todo el mundo — siempre gratis.
                        </p>

                        <div class="flex items-center gap-3 text-gray-600">
                            <a href="#" class="bg-gray-100 p-2.5 rounded-xl hover:bg-gray-200 hover:text-orange-500 transition">
                                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path></svg>
                            </a>
                            <a href="#" class="bg-gray-100 p-2.5 rounded-xl hover:bg-gray-200 hover:text-orange-500 transition">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line></svg>
                            </a>
                            <a href="#" class="bg-gray-100 p-2.5 rounded-xl hover:bg-gray-200 hover:text-orange-500 transition">
                                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.028zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"></path></svg>
                            </a>
                        </div>
                    </div>

                    <div>
                        <h3 class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-5">Plataforma</h3>
                        <ul class="space-y-3.5 text-sm text-gray-500">
                            <li><a href="/#catalogo" class="hover:text-orange-500 transition">Explorar Historias</a></li>
                            <li><a href="/upload" class="hover:text-orange-500 transition">Subir Historia</a></li>
                            <li><a href="#" class="hover:text-orange-500 transition">Listas de Lectura</a></li>
                            <li><a href="#" class="hover:text-orange-500 transition">Retos</a></li>
                            <li><a href="#" class="hover:text-orange-500 transition">Tendencias</a></li>
                        </ul>
                    </div>

                    <div>
                        <h3 class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-5">Compañía</h3>
                        <ul class="space-y-3.5 text-sm text-gray-500">
                            <li><a href="#" class="hover:text-orange-500 transition">Sobre Folio</a></li>
                            <li><a href="/blog" class="hover:text-orange-500 transition">Blog</a></li>
                            <li><a href="#" class="hover:text-orange-500 transition">Empleo</a></li>
                            <li><a href="#" class="hover:text-orange-500 transition">Prensa</a></li>
                        </ul>
                    </div>

                    <div>
                        <h3 class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-5">Soporte</h3>
                        <ul class="space-y-3.5 text-sm text-gray-500">
                            <li><a href="#" class="hover:text-orange-500 transition">Centro de Ayuda</a></li>
                            <li><a href="#" class="hover:text-orange-500 transition">Comunidad</a></li>
                            <li><a href="#" class="hover:text-orange-500 transition">Normas</a></li>
                            <li><a href="#" class="hover:text-orange-500 transition">Privacidad</a></li>
                            <li><a href="#" class="hover:text-orange-500 transition">Términos</a></li>
                        </ul>
                    </div>
                </div>

                <div class="border-t border-gray-100 pt-8 flex flex-col md:flex-row items-center justify-between gap-4 text-sm text-gray-400">
                    <p>© 2026 Folio. Todos los derechos reservados.</p>
                    <p class="flex items-center gap-1">
                        Hecho con <span class="text-red-400 text-lg leading-none">♥</span> para lectores
                    </p>
                </div>
            </div>
        </footer>
    </body>
</html>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // --- 1. AUTENTICACIÓN Y ESTADO GLOBAL ---
    const token = sessionStorage.getItem('folio_token');
    const userString = sessionStorage.getItem('folio_user');
    const isLogged = !!(token && userString); 
    
    const loggedOutMenu = document.getElementById('loggedOutMenu');
    const loggedInMenu = document.getElementById('loggedInMenu');
    
    if (isLogged) {
      const user = JSON.parse(userString);
      document.getElementById('userName').textContent = user.username;
      document.getElementById('userAvatar').textContent = user.username.charAt(0).toUpperCase();
      
      loggedInMenu.classList.remove('hidden');
      loggedInMenu.classList.add('flex');
      
      document.getElementById('logoutBtn').addEventListener('click', () => {
        sessionStorage.removeItem('folio_token');
        sessionStorage.removeItem('folio_user');
        window.location.reload(); 
      });
    } else {
      loggedOutMenu.classList.remove('hidden');
      loggedOutMenu.classList.add('flex');
    }

    // --- 2. LÓGICA DEL MINI MODAL (AVISO DE LOGIN) ---
    const authModal = document.getElementById('authModal');
    const authBackdrop = document.getElementById('authModalBackdrop');
    const closeAuthBtn = document.getElementById('closeAuthModalBtn');

    const showAuthModal = () => {
        if(authModal) {
            authModal.classList.remove('hidden');
            document.body.style.overflow = 'hidden';
        }
    };
    
    const hideAuthModal = () => {
        if(authModal) {
            authModal.classList.add('hidden');
            document.body.style.overflow = '';
        }
    };

    if(closeAuthBtn) closeAuthBtn.addEventListener('click', hideAuthModal);
    if(authBackdrop) authBackdrop.addEventListener('click', hideAuthModal);

    const uploadLinks = document.querySelectorAll('a[href="/upload"]');
    uploadLinks.forEach(link => {
        link.addEventListener('click', (e) => {
            if (!isLogged) {
                e.preventDefault(); 
                showAuthModal();    
            }
        });
    });

    // --- 3. LÓGICA DE FILTROS Y BUSCADOR COMBINADOS ---
    const filterBtns = document.querySelectorAll('.filter-btn');
    const storyCards = document.querySelectorAll('.story-card');
    const storyCounter = document.getElementById('story-counter');
    const searchInput = document.getElementById('searchInput');
    const ratingFilter = document.getElementById('ratingFilter');
    const ratingDisplay = document.getElementById('ratingDisplay');

    let generoActivo = 'all';
    let busquedaActiva = '';
    let ratingMinimo = 0; 

    const updateCounter = (count) => {
      if(storyCounter) {
          storyCounter.textContent = `${count} historia${count !== 1 ? 's' : ''} encontrada${count !== 1 ? 's' : ''}`;
      }
    };
    
    updateCounter(storyCards.length);

    const aplicarFiltrosYBusqueda = () => {
        let visibleCount = 0;

        storyCards.forEach(card => {
            const cardGenero = card.getAttribute('data-genero');
            const cardTitulo = (card.getAttribute('data-titulo') || '').toLowerCase();
            const cardAutor = (card.getAttribute('data-autor') || '').toLowerCase();
            const cardRating = parseFloat(card.getAttribute('data-rating')) || 0; 

            const coincideGenero = generoActivo === 'all' || cardGenero === generoActivo;
            const coincideBusqueda = cardTitulo.includes(busquedaActiva) || cardAutor.includes(busquedaActiva);
            const coincideRating = cardRating >= ratingMinimo;

            if (coincideGenero && coincideBusqueda && coincideRating) {
                card.style.display = ''; 
                visibleCount++;
            } else {
                card.style.display = 'none';
            }
        });

        updateCounter(visibleCount);
    };

    if (ratingFilter) {
        ratingFilter.addEventListener('input', (e) => {
            ratingMinimo = parseFloat(e.target.value);
            if(ratingDisplay) {
                ratingDisplay.textContent = ratingMinimo === 0 ? 'Todas' : `${ratingMinimo.toFixed(1)} ★`;
            }
            aplicarFiltrosYBusqueda();
        });
    }

    if (searchInput) {
        searchInput.addEventListener('input', (e) => {
            busquedaActiva = e.target.value.toLowerCase().trim();
            aplicarFiltrosYBusqueda();
        });
    }

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        generoActivo = btn.getAttribute('data-filter');
        filterBtns.forEach(b => {
          b.classList.remove('bg-gray-900', 'text-white');
          b.classList.add('bg-gray-100', 'text-gray-700');
        });
        btn.classList.remove('bg-gray-100', 'text-gray-700');
        btn.classList.add('bg-gray-900', 'text-white');
        aplicarFiltrosYBusqueda();
      });
    });

    // --- 4. MODAL DE LA HISTORIA PRINCIPAL Y CARGA DEL CHAT ---
    const modal = document.getElementById('storyModal');
    const backdrop = document.getElementById('modalBackdrop');
    const closeBtn = document.getElementById('closeModalBtn');
    
    const mCover = document.getElementById('modalCover');
    const mGenre = document.getElementById('modalGenre');
    const mTitle = document.getElementById('modalTitle');
    const mAuthor = document.getElementById('modalAuthor');
    const mRating = document.getElementById('modalRating');
    const mSynopsis = document.getElementById('modalSynopsis');
    const mReadBtn = document.getElementById('modalReadBtn');
    
    const chatMessages = document.getElementById('chatMessages');
    let currentHistoriaId = null; 

    const pintarMensaje = (nombre, texto, esPropio) => {
        const inicial = nombre.charAt(0).toUpperCase();
        const colorAvatar = esPropio ? 'bg-gray-900 text-white' : 'bg-orange-100 text-orange-600';
        const colorTexto = esPropio ? 'text-gray-800' : 'text-gray-600';
        
        return `
            <div class="flex gap-3">
                <div class="w-8 h-8 rounded-full ${colorAvatar} flex items-center justify-center font-bold text-xs flex-shrink-0">${inicial}</div>
                <div class="bg-white border border-gray-100 p-3 rounded-2xl rounded-tl-none shadow-sm text-sm ${colorTexto}">
                    <span class="font-bold text-gray-900 block mb-1">${nombre}</span>
                    ${texto}
                </div>
            </div>
        `;
    };

    storyCards.forEach(card => {
        card.addEventListener('click', async () => {
            currentHistoriaId = card.getAttribute('data-id'); 
            
            const titulo = card.getAttribute('data-titulo');
            const autor = card.getAttribute('data-autor');
            const sinopsis = card.getAttribute('data-sinopsis');
            const portada = card.getAttribute('data-portada');
            const pdf = card.getAttribute('data-pdf');
            const genero = card.getAttribute('data-genero');
            const rating = card.getAttribute('data-rating');

            mCover.src = portada;
            mTitle.textContent = titulo;
            mAuthor.textContent = `por ${autor}`;
            mGenre.textContent = genero;
            mRating.textContent = rating;
            mSynopsis.textContent = sinopsis;
            
            // Resetear estrellas interactivas del modal a 5 por defecto cada vez que se abre un libro
            estrellasSeleccionadas = 5;
            stars.forEach(s => { s.classList.remove('text-gray-300'); s.classList.add('text-orange-400'); });

            if (pdf && pdf !== '#') {
                mReadBtn.setAttribute('data-pdf-url', pdf);
                mReadBtn.setAttribute('data-filename', `${titulo.replace(/[^a-zA-Z0-9]/g, '_')}_Folio.pdf`);
                mReadBtn.classList.remove('opacity-50', 'cursor-not-allowed');
                mReadBtn.innerHTML = `Descargar Manuscrito <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>`;
            } else {
                mReadBtn.removeAttribute('data-pdf-url');
                mReadBtn.classList.add('opacity-50', 'cursor-not-allowed');
                mReadBtn.textContent = 'Manuscrito no disponible';
            }

            chatMessages.innerHTML = '<p class="text-xs text-center text-gray-400 py-4">Cargando comentarios...</p>';
            
            try {
                const res = await fetch(`/aws/api/comentarios?filters[historia][id][$eq]=${currentHistoriaId}&sort=createdAt:asc`);                
                const json = await res.json();
                
                chatMessages.innerHTML = ''; 

                if (json.data && json.data.length > 0) {
                    const currentUser = isLogged ? JSON.parse(userString).username : null;
                    
                    json.data.forEach(msg => {
                        const nombreAutor = msg.attributes?.NombreUsuario || msg.NombreUsuario || "Usuario";
                        const textoCompleto = msg.attributes?.Texto || msg.Texto || "";
                        
                        let textoComentario = textoCompleto;
                        let valoracion = 0;

                        // --- DESCAMUFLAR EL VOTO ---
                        if (textoCompleto.startsWith('[')) {
                            const finBrackets = textoCompleto.indexOf(']');
                            if (finBrackets > 0) {
                                valoracion = parseInt(textoCompleto.substring(1, finBrackets)) || 0;
                                textoComentario = textoCompleto.substring(finBrackets + 1).trim();
                            }
                        }

                        // Añadimos las estrellitas visuales en el chat
                        let mensajeVisual = textoComentario;
                        if (valoracion > 0) {
                            const estrellasTexto = '★'.repeat(valoracion) + '☆'.repeat(5 - valoracion);
                            mensajeVisual = `${textoComentario} <br><span class="text-orange-400 text-xs mt-1 block">${estrellasTexto}</span>`;
                        }
                        
                        const esMio = nombreAutor === currentUser;
                        chatMessages.innerHTML += pintarMensaje(nombreAutor, mensajeVisual, esMio);
                    });
                } else {
                    chatMessages.innerHTML = '<p class="text-xs text-center text-gray-400 py-4">No hay comentarios aún. ¡Sé el primero!</p>';
                }
                chatMessages.scrollTop = chatMessages.scrollHeight; 
            } catch (error) {
                console.error("Error cargando chat:", error);
                chatMessages.innerHTML = '<p class="text-xs text-center text-red-400 py-4">Error al cargar los comentarios.</p>';
            }

            modal.classList.remove('hidden');
            document.body.style.overflow = 'hidden'; 
        });
    });

    const closeModal = () => {
        if(modal) {
            modal.classList.add('hidden');
            document.body.style.overflow = '';
        }
    };

    if(closeBtn) closeBtn.addEventListener('click', closeModal);
    if(backdrop) backdrop.addEventListener('click', closeModal);
    
    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
            closeModal();
            hideAuthModal();
        }
    });

    // --- 5. ACCIONES PROTEGIDAS DEL MODAL ---
    if(mReadBtn) {
        mReadBtn.addEventListener('click', async (e) => {
            e.preventDefault(); 
            
            if (!isLogged) {
                showAuthModal(); 
                return;
            }

            const pdfUrl = mReadBtn.getAttribute('data-pdf-url');
            const fileName = mReadBtn.getAttribute('data-filename') || 'historia.pdf';
            if (!pdfUrl) return;

            const originalText = mReadBtn.innerHTML;
            mReadBtn.innerHTML = 'Descargando... <svg class="w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>';
            mReadBtn.classList.add('opacity-70', 'pointer-events-none');

            try {
                const response = await fetch(pdfUrl);
                const blob = await response.blob();
                const url = window.URL.createObjectURL(blob);
                const tempLink = document.createElement('a');
                tempLink.style.display = 'none';
                tempLink.href = url;
                tempLink.download = fileName;
                document.body.appendChild(tempLink);
                tempLink.click();
                window.URL.revokeObjectURL(url);
                tempLink.remove();
            } catch (error) {
                console.error("Error descargando:", error);
                alert("No se pudo descargar el archivo.");
            } finally {
                mReadBtn.innerHTML = originalText;
                mReadBtn.classList.remove('opacity-70', 'pointer-events-none');
            }
        });
    }

    // --- LÓGICA DE LAS ESTRELLAS INTERACTIVAS ---
    const stars = document.querySelectorAll('#interactiveStars span');
    let estrellasSeleccionadas = 5; 

    stars.forEach((star, index) => {
        star.addEventListener('click', () => {
            if (!isLogged) {
                showAuthModal(); 
                return;
            }
            
            estrellasSeleccionadas = index + 1; 
            
            stars.forEach((s, i) => {
                if(i <= index) {
                    s.classList.remove('text-gray-300');
                    s.classList.add('text-orange-400');
                } else {
                    s.classList.add('text-gray-300');
                    s.classList.remove('text-orange-400');
                }
            });
        });
    });

    // --- ENVIAR CHAT Y CALCULAR LA MEDIA ---
    const chatForm = document.getElementById('chatForm');
    const chatInput = document.getElementById('chatInput');

    if(chatInput) {
        chatInput.addEventListener('focus', (e) => {
            if (!isLogged) {
                e.target.blur(); 
                showAuthModal(); 
            }
        });
    }

    if(chatForm) {
        chatForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            if (!isLogged) {
                showAuthModal();
                return;
            }

            const text = chatInput.value.trim();
            if (!text || !currentHistoriaId) return;

            const user = JSON.parse(userString);
            const botonEnvio = chatForm.querySelector('button');
            
            botonEnvio.disabled = true;
            botonEnvio.classList.add('opacity-50');

            // --- 1. ENVIAR EL COMENTARIO CON EL VOTO CAMUFLADO ---
            const textoCamuflado = `[${estrellasSeleccionadas}] ${text}`;

            try {
                const res = await fetch('/aws/api/comentarios', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${token}`
                    },
                    body: JSON.stringify({
                        data: {
                            Texto: textoCamuflado,
                            NombreUsuario: user.username,
                            historia: currentHistoriaId
                        }
                    })
                });

                if (res.ok) {
                    if (chatMessages.innerHTML.includes('No hay comentarios')) {
                        chatMessages.innerHTML = '';
                    }
                    
                    const estrellasTexto = '★'.repeat(estrellasSeleccionadas) + '☆'.repeat(5 - estrellasSeleccionadas);
                    const mensajeVisual = `${text} <br><span class="text-orange-400 text-xs mt-1 block">${estrellasTexto}</span>`;

                    chatMessages.insertAdjacentHTML('beforeend', pintarMensaje(user.username, mensajeVisual, true));
                    chatMessages.scrollTop = chatMessages.scrollHeight;
                    chatInput.value = '';

                    // --- 2. EL CALCULO MATEMÁTICO DE LA MEDIA ---
                    const resComentarios = await fetch(`/aws/api/comentarios?filters[historia][id][$eq]=${currentHistoriaId}`);
                    const jsonComentarios = await resComentarios.json();
                    
                    let sumaVotos = 0;
                    let totalVotos = 0;
                    
                    if (jsonComentarios.data) {
                        jsonComentarios.data.forEach(c => {
                            const txt = c.attributes?.Texto || c.Texto || "";
                            if (txt.startsWith('[')) {
                                const fin = txt.indexOf(']');
                                const voto = parseInt(txt.substring(1, fin));
                                if (voto > 0) {
                                    sumaVotos += voto;
                                    totalVotos++;
                                }
                            }
                        });
                    }
                    
                    // Calculamos la nota media con 1 decimal (ej: 4.3)
                    const nuevaMedia = totalVotos > 0 ? (sumaVotos / totalVotos).toFixed(1) : "0.0";
                    
                    // --- 3. ACTUALIZAR EL RATING EN LA COLECCIÓN DE HISTORIAS DE STRAPI ---
                    await fetch(`/aws/api/historias/${currentHistoriaId}`, {
                        method: 'PUT',
                        headers: {
                            'Content-Type': 'application/json',
                            'Authorization': `Bearer ${token}`
                        },
                        body: JSON.stringify({
                            data: {
                                Rating: nuevaMedia // Sobrescribimos el rating existente con el nuevo promedio
                            }
                        })
                    });

                    // Actualizamos la nota visual del modal al instante
                    mRating.textContent = nuevaMedia;
                    
                    // Actualizamos el atributo de la tarjeta del catálogo para que el filtro de barra responda en vivo
                    const tarjetaCatalogo = document.querySelector(`.story-card[data-id="${currentHistoriaId}"]`);
                    if (tarjetaCatalogo) {
                        tarjetaCatalogo.setAttribute('data-rating', nuevaMedia);
                        const labelRatingTarjeta = tarjetaCatalogo.querySelector('.font-bold.text-gray-700');
                        if (labelRatingTarjeta) labelRatingTarjeta.textContent = nuevaMedia;
                    }

                } else {
                    console.error("Strapi rechazó el mensaje.");
                }
            } catch (error) {
                console.error("Error de red procesando la valoración:", error);
            } finally {
                botonEnvio.disabled = false;
                botonEnvio.classList.remove('opacity-50');
            }
        });
    }
  });
</script>