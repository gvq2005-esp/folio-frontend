---
// src/pages/index.astro
import "../styles/global.css";

// 1. Declaramos el logo por defecto
let logoUrl = "/favicon.svg";

// 2. Declaramos la variable historias como un array vacío
let historias = [];

try {
    // --- PETICIÓN DEL LOGO ---
    const logoResponse = await fetch(
        "http://51.21.220.203/api/Logo?populate=*",
    );
    const logoJson = await logoResponse.json();

    const logoPath = logoJson.data?.logo?.url || logoJson.data?.logo?.[0]?.url;
    if (logoPath) {
        logoUrl = `/aws${logoPath}`;
    }

    // --- PETICIÓN DE LAS HISTORIAS ---
    const historiasResponse = await fetch(
        "http://51.21.220.203/api/historias?populate=*",
    );
    const historiasJson = await historiasResponse.json();

    // Llenamos nuestra variable con los datos de Strapi
    historias = historiasJson.data || [];
} catch (error) {
    console.error("Error conectando con Strapi:", error);
}

let generos = [];
try {
    const generosResponse = await fetch("http://51.21.220.203/api/generos");
    const generosJson = await generosResponse.json();
    generos = generosJson.data || [];
} catch (error) {
    console.error("Error cargando géneros:", error);
}

// --- NUEVA PETICIÓN: CONTAR USUARIOS (LECTORES) ---
let numLectores = 0;
try {
    const usersResponse = await fetch("http://51.21.220.203/api/users");
    if (usersResponse.ok) {
        const usersJson = await usersResponse.json();
        numLectores = usersJson.length || 0; 
    }
} catch (error) {
    console.error("Error cargando usuarios:", error);
}
---

<html lang="es" class="scroll-smooth">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/png" href={logoUrl} />
        <meta name="viewport" content="width=device-width" />
        <title>Folio | Plataforma de Historias</title>
    </head>
    <body class="bg-gray-50 text-gray-900 font-sans antialiased">
        <header class="bg-gray-50 border-b border-gray-100 sticky top-0 z-50">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-20 flex items-center justify-between gap-6">
                <a href="/" class="flex items-center gap-2.5 flex-shrink-0">
                    <div class="h-16 w-16 flex items-center justify-center overflow-hidden">
                        <img src={logoUrl} alt="Logo Folio" class="h-full w-full object-contain p-1" />
                    </div>
                    <span class="text-3xl font-extrabold tracking-tighter text-gray-950">Folio<span class="text-orange-500">.</span></span>
                </a>

                <nav class="flex items-center gap-8 text-md font-medium flex-shrink-0 ml-auto">
                    <a href="#catalogo" class="text-gray-700 hover:text-orange-600 transition">Explorar</a>
                    <a href="/blog" class="text-gray-700 hover:text-orange-600 transition">Blog</a>
                    <a href="/upload" id="navUploadBtn" class="text-gray-700 hover:text-orange-600 transition">Subir historia</a>

                    <div id="loggedOutMenu" class="items-center gap-8 hidden">
                        <a href="/login" class="text-gray-700 hover:text-orange-600 transition">Iniciar sesión</a>
                        <a href="/register" class="bg-orange-500 text-white px-8 py-3.5 rounded-full font-semibold hover:bg-orange-600 transition shadow-md active:scale-95">Crear cuenta</a>
                    </div>

                    <div id="loggedInMenu" class="items-center gap-6 hidden">
                        <div class="flex items-center gap-3 cursor-pointer group">
                            <div id="userAvatar" class="w-10 h-10 rounded-full bg-orange-100 text-orange-600 border border-orange-200 flex items-center justify-center font-extrabold text-sm group-hover:bg-orange-500 group-hover:text-white transition-colors">U</div>
                            <span id="userName" class="font-bold text-gray-900 group-hover:text-orange-600 transition-colors">Usuario</span>
                        </div>
                        <button id="logoutBtn" class="text-sm font-semibold text-gray-400 hover:text-red-500 transition">Cerrar sesión</button>
                    </div>
                </nav>
            </div>
        </header>

        <main>
            <section class="relative bg-white text-gray-900 min-h-[80vh] flex flex-col items-center justify-center pt-20 pb-12 overflow-hidden font-sans antialiased">
                <div class="absolute inset-0 opacity-[0.03]">
                    <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
                        <defs>
                            <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
                                <path d="M 40 0 L 0 0 0 40" fill="none" stroke="black" stroke-width="1"></path>
                            </pattern>
                        </defs>
                        <rect width="100%" height="100%" fill="url(#grid)"></rect>
                    </svg>
                </div>

                <div class="max-w-4xl mx-auto px-6 text-center relative z-10 flex flex-col items-center flex-grow justify-center">
                    <h1 class="text-5xl md:text-6xl font-extrabold tracking-tighter text-gray-950 mb-8 leading-[1.1]">
                        Tu próxima <span class="text-orange-500">historia favorita</span><br /> comienza aquí.
                    </h1>

                    <p class="text-lg md:text-xl text-gray-600 mb-12 max-w-2xl mx-auto font-medium">
                        Descubre miles de historias de autores independientes de todo el mundo. Lee gratis. Escribe libremente. Encuentra tu comunidad.
                    </p>

                    <div class="flex flex-col sm:flex-row gap-4 mb-20 justify-center">
                        <a href="#catalogo" class="bg-orange-500 text-white px-10 py-4 rounded-full font-bold text-lg hover:bg-orange-600 transition duration-300 shadow-md flex items-center gap-3 justify-center">
                            <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14.5v-9l6 4.5-6 4.5z"></path></svg>
                            Empezar a leer
                        </a>
                        <a href="/upload" class="bg-white text-gray-700 px-10 py-4 rounded-full font-semibold text-lg hover:bg-gray-50 transition duration-300 border border-gray-300 shadow-sm flex items-center gap-3 justify-center">
                            <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24"><path d="M19 3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-2 10h-4v4h-2v-4H7v-2h4V7h2v4h4v2z"></path></svg>
                            Sube tu historia
                        </a>
                    </div>
                </div>

                <div class="w-full max-w-7xl mx-auto px-6 mt-auto relative z-10">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 py-10 border-t border-gray-200 text-center max-w-2xl mx-auto">
                        <div class="flex flex-col items-center">
                            <span class="text-5xl font-extrabold tracking-tighter text-orange-500 mb-1">{historias.length}</span>
                            <span class="text-sm font-semibold text-gray-500 uppercase tracking-widest">Historias</span>
                        </div>
                        <div class="flex flex-col items-center">
                            <span class="text-5xl font-extrabold tracking-tighter text-orange-500 mb-1">{numLectores}</span>
                            <span class="text-sm font-semibold text-gray-500 uppercase tracking-widest">Lectores</span>
                        </div>
                    </div>
                </div>
            </section>

            <section id="catalogo" class="scroll-mt-24 bg-gray-50/50 py-16 border-t border-gray-200">
                <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                    <div class="text-center mb-10">
                        <span class="text-xs font-bold text-orange-500 uppercase tracking-widest">Catálogo</span>
                        <h2 class="text-3xl font-extrabold text-gray-900 mt-1">Historias Destacadas</h2>
                    </div>

                    <div class="flex flex-col lg:flex-row gap-8">
                        <aside class="w-full lg:w-72 flex-shrink-0">
                            <div class="bg-white rounded-2xl border border-gray-200 p-6 shadow-sm sticky top-28">
                                <div class="mb-6">
                                    <h3 class="font-bold text-gray-900">Filtros</h3>
                                    <p id="story-counter" class="text-xs text-gray-500">Cargando historias...</p>
                                </div>

                                <div class="mb-8">
                                    <h4 class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-3">Buscar</h4>
                                    <div class="relative">
                                        <div class="absolute left-3 top-1/2 -translate-y-1/2 text-orange-500">
                                            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                                        </div>
                                        <input type="text" id="searchInput" placeholder="Títulos o autores..." class="w-full bg-gray-50 border border-gray-200 rounded-xl py-2.5 pl-10 pr-4 text-sm placeholder:text-gray-400 focus:ring-2 focus:ring-orange-200 focus:border-orange-500 transition-all outline-none shadow-inner" />
                                    </div>
                                </div>

                                <div class="mb-8">
                                    <h4 class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-3">Género</h4>
                                    <div class="flex flex-wrap gap-2 pb-4 mb-6">
                                        <button data-filter="all" class="filter-btn px-4 py-1.5 text-sm rounded-full bg-gray-900 text-white font-semibold transition">Todos</button>
                                        {
                                            generos.map((gen) => {
                                                const nombre = gen.attributes ? gen.attributes.Nombre : gen.Nombre;
                                                return (
                                                    <button data-filter={nombre} class="filter-btn px-4 py-1.5 text-sm rounded-full bg-gray-100 text-gray-700 font-semibold hover:bg-orange-100 hover:text-orange-600 transition">{nombre}</button>
                                                );
                                            })
                                        }
                                    </div>
                                </div>
                            </div>
                        </aside>

                        <div class="flex-1">
                            <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-6">
                                {
                                    historias.length === 0 ? (
                                        <div class="col-span-full text-center py-12 text-gray-500 bg-white rounded-2xl border border-dashed border-gray-300">
                                            Todavía no hay historias publicadas. ¡Sé el primero en subir una!
                                        </div>
                                    ) : (
                                        historias.map((historia) => {
                                            const titulo = historia.attributes?.Titulo || historia.Titulo || "Sin título";
                                            const autor = historia.attributes?.Autor || historia.Autor || "Autor Independiente";
                                            const sinopsis = historia.attributes?.Sinopsis || historia.Sinopsis || "No hay sinopsis disponible.";

                                            const portadaRelativa = historia.Portada?.url || historia.attributes?.Portada?.data?.attributes?.url;
                                            const portadaUrl = portadaRelativa ? `/aws${portadaRelativa}` : "/placeholder-cover.jpg";

                                            const generoRaw = historia.attributes?.genero || historia.attributes?.Genero || historia.genero || historia.Genero;
                                            const generoNombre = generoRaw?.data?.attributes?.Nombre || generoRaw?.Nombre || "Sin género";

                                            const pdfRelativa = historia.PDF?.url || historia.attributes?.PDF?.data?.attributes?.url;
                                            const pdfUrl = pdfRelativa ? `/aws${pdfRelativa}` : "#";

                                            const docId = historia.documentId || historia.id;

                                            return (
                                                <article
                                                    class="story-card bg-white rounded-2xl border border-gray-200 overflow-hidden shadow-sm hover:shadow-md transition-shadow group cursor-pointer flex flex-col h-full"
                                                    data-id={historia.id}
                                                    data-docid={docId}
                                                    data-titulo={titulo}
                                                    data-autor={autor}
                                                    data-sinopsis={sinopsis}
                                                    data-portada={portadaUrl}
                                                    data-pdf={pdfUrl}
                                                    data-genero={generoNombre}
                                                >
                                                    <div class="relative bg-gray-200 aspect-[3/4] w-full overflow-hidden">
                                                        <img src={portadaUrl} alt={`Portada de ${titulo}`} class="h-full w-full object-cover group-hover:scale-105 transition-transform duration-300" />
                                                        <div class="absolute top-3 left-3 flex items-center gap-2">
                                                            <span class="bg-orange-500 text-white text-[10px] font-bold uppercase tracking-wider px-2 py-1 rounded-md flex items-center gap-1 shadow-sm">
                                                                ★ Destacado
                                                            </span>
                                                        </div>
                                                    </div>

                                                    <div class="p-5 flex flex-col flex-grow">
                                                        <span class="text-orange-600 bg-orange-50 text-[10px] font-bold uppercase tracking-widest px-2 py-1 rounded-md self-start mb-3 border border-orange-100">
                                                            {generoNombre}
                                                        </span>

                                                        <h3 class="font-bold text-gray-900 text-lg leading-tight mb-1 group-hover:text-orange-600 transition-colors line-clamp-1" title={titulo}>{titulo}</h3>
                                                        <p class="text-xs text-gray-500 mb-3">De {autor}</p>
                                                        <p class="text-sm text-gray-600 line-clamp-3 mb-4 flex-grow" title={sinopsis}>{sinopsis}</p>

                                                        <div class="flex items-center justify-end mt-auto pt-4 border-t border-gray-100">
                                                            <a class="text-orange-500 text-xs font-bold flex items-center gap-1 group-hover:translate-x-1 transition-transform z-10 hover:text-orange-700">
                                                                Ver más
                                                                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
                                                            </a>
                                                        </div>
                                                    </div>
                                                </article>
                                            );
                                        })
                                    )
                                }
                            </div>

                            <div id="loadMoreContainer" class="mt-12 justify-center hidden">
                                <button id="loadMoreBtn" class="flex items-center gap-2 border border-gray-300 bg-white text-gray-700 px-6 py-2.5 rounded-full text-sm font-semibold hover:bg-gray-50 transition shadow-sm">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
                                    Cargar más historias
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <div id="storyModal" class="fixed inset-0 z-[100] hidden flex items-center justify-center px-4">
                <div id="modalBackdrop" class="absolute inset-0 bg-gray-900/40 backdrop-blur-sm transition-opacity"></div>
                <div class="relative bg-white rounded-3xl w-full max-w-4xl max-h-[90vh] overflow-hidden shadow-2xl flex flex-col md:flex-row z-10 animate-fade-in-up">
                    <button id="closeModalBtn" class="absolute top-4 right-4 bg-gray-100 hover:bg-gray-200 text-gray-600 p-2 rounded-full transition z-20">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                    </button>

                    <div class="w-full md:w-1/2 bg-gray-50 p-8 overflow-y-auto border-r border-gray-100 flex flex-col">
                        <div class="flex gap-6 mb-6">
                            <img id="modalCover" src="" alt="Portada" class="w-32 h-48 object-cover rounded-xl shadow-md border border-gray-200" />
                            <div class="flex flex-col justify-center">
                                <span id="modalGenre" class="text-[10px] font-bold uppercase tracking-widest text-orange-600 bg-orange-100 px-2 py-1 rounded-md self-start mb-2"></span>
                                <h2 id="modalTitle" class="text-2xl font-extrabold text-gray-900 leading-tight mb-1"></h2>
                                <p id="modalAuthor" class="text-sm font-medium text-gray-500 mb-3"></p>
                            </div>
                        </div>

                        <div class="mb-8 flex-grow">
                            <h3 class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-2">Sinopsis</h3>
                            <p id="modalSynopsis" class="text-gray-600 text-sm leading-relaxed"></p>
                        </div>
                        
                        <a id="modalReadBtn" href="#" class="w-full bg-orange-500 text-white text-center py-3.5 rounded-xl font-bold hover:bg-orange-600 transition shadow-md flex items-center justify-center gap-2 mt-auto">
                            Descargar Manuscrito
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                        </a>

                        <button id="modalDeleteBtn" class="w-full bg-white text-red-500 border border-red-200 text-center py-3.5 rounded-xl font-bold hover:bg-red-50 transition shadow-sm flex items-center justify-center gap-2 mt-3 hidden">
                            Eliminar Historia
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                        </button>
                    </div>

                    <div class="w-full md:w-1/2 flex flex-col bg-white">
                        <div class="p-6 border-b border-gray-100">
                            <h3 class="font-bold text-gray-900 flex items-center gap-2">
                                <svg class="w-5 h-5 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path></svg>
                                Reseñas y Comentarios
                            </h3>
                        </div>

                        <div id="chatMessages" class="flex-grow overflow-y-auto p-6 space-y-4 bg-gray-50/30"></div>

                        <div class="p-4 border-t border-gray-100 bg-white">
                            <form id="chatForm" class="flex items-end gap-2">
                                <textarea id="chatInput" rows="1" placeholder="Escribe tu reseña..." class="w-full bg-gray-50 border border-gray-200 rounded-xl py-3 px-4 text-sm outline-none focus:ring-2 focus:ring-orange-200 focus:border-orange-500 transition resize-none"></textarea>
                                <button type="submit" class="bg-gray-900 text-white p-3 rounded-xl hover:bg-orange-500 transition flex-shrink-0">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path></svg>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>

            <div id="authModal" class="fixed inset-0 z-[200] hidden flex items-center justify-center px-4">
                <div id="authModalBackdrop" class="absolute inset-0 bg-gray-900/60 backdrop-blur-sm transition-opacity"></div>
                <div class="relative bg-white rounded-3xl w-full max-w-sm p-8 text-center shadow-2xl z-10 animate-fade-in-up">
                    <button id="closeAuthModalBtn" class="absolute top-4 right-4 text-gray-400 hover:text-gray-600 transition">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                    </button>

                    <div class="w-16 h-16 bg-orange-100 text-orange-500 rounded-full flex items-center justify-center mx-auto mb-5 shadow-inner">
                        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8V7z"></path></svg>
                    </div>

                    <h3 class="text-2xl font-extrabold text-gray-900 mb-2 tracking-tight">¡Un momento!</h3>
                    <p class="text-gray-500 text-sm mb-8 leading-relaxed">Debes iniciar sesión o crear una cuenta gratuita para acceder a esta función de la comunidad.</p>

                    <div class="flex flex-col gap-3">
                        <a href="/login" class="w-full bg-gray-900 text-white py-3.5 rounded-xl font-bold hover:bg-gray-800 transition shadow-md">Iniciar sesión</a>
                        <a href="/register" class="w-full bg-orange-50 text-orange-600 py-3.5 rounded-xl font-bold hover:bg-orange-100 transition border border-orange-100 shadow-sm">Crear cuenta gratis</a>
                    </div>
                </div>
            </div>
        </main>

        <footer class="bg-white border-t border-gray-100 pt-16 pb-8 mt-12">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="border-t border-gray-100 pt-8 flex flex-col md:flex-row items-center justify-between gap-4 text-sm text-gray-400">
                    <p>© 2026 Folio. Todos los derechos reservados.</p>
                    <p class="flex items-center gap-1">Hecho con <span class="text-red-400 text-lg leading-none">♥</span> para lectores</p>
                </div>
            </div>
        </footer>
    </body>
</html>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        // --- 1. AUTENTICACIÓN Y ESTADO GLOBAL ---
        const token = sessionStorage.getItem("folio_token");
        const userString = sessionStorage.getItem("folio_user");
        const isLogged = !!(token && userString);

        const loggedOutMenu = document.getElementById("loggedOutMenu");
        const loggedInMenu = document.getElementById("loggedInMenu");

        if (isLogged) {
            const user = JSON.parse(userString);
            const userNameEl = document.getElementById("userName");
            const userAvatarEl = document.getElementById("userAvatar");
            
            if(userNameEl) userNameEl.textContent = user.username;
            if(userAvatarEl) userAvatarEl.textContent = user.username.charAt(0).toUpperCase();

            if(loggedInMenu) {
                loggedInMenu.classList.remove("hidden");
                loggedInMenu.classList.add("flex");
            }

            const logoutBtn = document.getElementById("logoutBtn");
            if(logoutBtn) {
                logoutBtn.addEventListener("click", () => {
                    sessionStorage.removeItem("folio_token");
                    sessionStorage.removeItem("folio_user");
                    window.location.reload();
                });
            }
        } else {
            if(loggedOutMenu) {
                loggedOutMenu.classList.remove("hidden");
                loggedOutMenu.classList.add("flex");
            }
        }

        // --- 2. LÓGICA DEL MINI MODAL (AVISO DE LOGIN) ---
        const authModal = document.getElementById("authModal");
        const authBackdrop = document.getElementById("authModalBackdrop");
        const closeAuthBtn = document.getElementById("closeAuthModalBtn");

        const showAuthModal = () => {
            if (authModal) {
                authModal.classList.remove("hidden");
                document.body.style.overflow = "hidden";
            }
        };

        const hideAuthModal = () => {
            if (authModal) {
                authModal.classList.add("hidden");
                document.body.style.overflow = "";
            }
        };

        if (closeAuthBtn) closeAuthBtn.addEventListener("click", hideAuthModal);
        if (authBackdrop) authBackdrop.addEventListener("click", hideAuthModal);

        const uploadLinks = document.querySelectorAll('a[href="/upload"]');
        uploadLinks.forEach((link) => {
            link.addEventListener("click", (e) => {
                if (!isLogged) {
                    e.preventDefault();
                    showAuthModal();
                }
            });
        });

        // --- 3. LÓGICA DE FILTROS, BUSCADOR Y PAGINACIÓN ---
        const filterBtns = document.querySelectorAll(".filter-btn");
        const storyCards = document.querySelectorAll(".story-card");
        const storyCounter = document.getElementById("story-counter");
        const searchInput = document.getElementById("searchInput");
        const loadMoreContainer = document.getElementById("loadMoreContainer");
        const loadMoreBtn = document.getElementById("loadMoreBtn");

        let generoActivo = "all";
        let busquedaActiva = "";
        
        // CONFIGURACIÓN DE PAGINACIÓN
        const CARDS_PER_PAGE = 6;
        let currentPage = 1;

        const updateCounter = (count) => {
            if (storyCounter) {
                storyCounter.textContent = `${count} historia${count !== 1 ? "s" : ""} encontrada${count !== 1 ? "s" : ""}`;
            }
        };

        const aplicarFiltrosYBusqueda = (resetPage = true) => {
            if (resetPage) currentPage = 1; 

            let matchCount = 0;   
            let visibleCount = 0; 

            storyCards.forEach((card) => {
                const cardGenero = card.getAttribute("data-genero");
                const cardTitulo = (card.getAttribute("data-titulo") || "").toLowerCase();
                const cardAutor = (card.getAttribute("data-autor") || "").toLowerCase();

                const coincideGenero = generoActivo === "all" || cardGenero === generoActivo;
                const coincideBusqueda = cardTitulo.includes(busquedaActiva) || cardAutor.includes(busquedaActiva);

                if (coincideGenero && coincideBusqueda) {
                    matchCount++;
                    if (visibleCount < currentPage * CARDS_PER_PAGE) {
                        card.style.display = "";
                        visibleCount++;
                    } else {
                        card.style.display = "none";
                    }
                } else {
                    card.style.display = "none";
                }
            });

            updateCounter(matchCount);

            if (loadMoreContainer) {
                if (matchCount > visibleCount) {
                    loadMoreContainer.classList.remove("hidden");
                    loadMoreContainer.classList.add("flex");
                } else {
                    loadMoreContainer.classList.add("hidden");
                    loadMoreContainer.classList.remove("flex");
                }
            }
        };

        // Inicializamos la primera vez que carga la web
        aplicarFiltrosYBusqueda();

        if (loadMoreBtn) {
            loadMoreBtn.addEventListener("click", () => {
                currentPage++; 
                aplicarFiltrosYBusqueda(false); 
            });
        }

        if (searchInput) {
            searchInput.addEventListener("input", (e) => {
                busquedaActiva = e.target.value.toLowerCase().trim();
                aplicarFiltrosYBusqueda(true);
            });
        }

        filterBtns.forEach((btn) => {
            btn.addEventListener("click", () => {
                generoActivo = btn.getAttribute("data-filter");
                filterBtns.forEach((b) => {
                    b.classList.remove("bg-gray-900", "text-white");
                    b.classList.add("bg-gray-100", "text-gray-700");
                });
                btn.classList.remove("bg-gray-100", "text-gray-700");
                btn.classList.add("bg-gray-900", "text-white");
                aplicarFiltrosYBusqueda(true);
            });
        });

        // --- 4. MODAL DE LA HISTORIA PRINCIPAL Y CARGA DEL CHAT ---
        const modal = document.getElementById("storyModal");
        const backdrop = document.getElementById("modalBackdrop");
        const closeBtn = document.getElementById("closeModalBtn");

        const mCover = document.getElementById("modalCover");
        const mGenre = document.getElementById("modalGenre");
        const mTitle = document.getElementById("modalTitle");
        const mAuthor = document.getElementById("modalAuthor");
        const mSynopsis = document.getElementById("modalSynopsis");
        const mReadBtn = document.getElementById("modalReadBtn");
        const mDeleteBtn = document.getElementById("modalDeleteBtn"); 

        const chatMessages = document.getElementById("chatMessages");
        
        let currentHistoriaId = null;
        let currentHistoriaDocId = null;

        const pintarMensaje = (nombre, texto, esPropio) => {
            const inicial = nombre.charAt(0).toUpperCase();
            const colorAvatar = esPropio ? "bg-gray-900 text-white" : "bg-orange-100 text-orange-600";
            const colorTexto = esPropio ? "text-gray-800" : "text-gray-600";

            return `
            <div class="flex gap-3">
                <div class="w-8 h-8 rounded-full ${colorAvatar} flex items-center justify-center font-bold text-xs flex-shrink-0">${inicial}</div>
                <div class="bg-white border border-gray-100 p-3 rounded-2xl rounded-tl-none shadow-sm text-sm ${colorTexto}">
                    <span class="font-bold text-gray-900 block mb-1">${nombre}</span>
                    ${texto}
                </div>
            </div>
            `;
        };

        storyCards.forEach((card) => {
            card.addEventListener("click", async () => {
                currentHistoriaId = card.getAttribute("data-id");
                currentHistoriaDocId = card.getAttribute("data-docid");

                const titulo = card.getAttribute("data-titulo");
                const autor = card.getAttribute("data-autor");
                const sinopsis = card.getAttribute("data-sinopsis");
                const portada = card.getAttribute("data-portada");
                const pdf = card.getAttribute("data-pdf");
                const genero = card.getAttribute("data-genero");

                if(mCover) mCover.src = portada;
                if(mTitle) mTitle.textContent = titulo;
                if(mAuthor) mAuthor.textContent = `por ${autor}`;
                if(mGenre) mGenre.textContent = genero;
                if(mSynopsis) mSynopsis.textContent = sinopsis;

                if (mReadBtn) {
                    if (pdf && pdf !== "#") {
                        mReadBtn.setAttribute("data-pdf-url", pdf);
                        mReadBtn.setAttribute("data-filename", `${titulo.replace(/[^a-zA-Z0-9]/g, "_")}_Folio.pdf`);
                        mReadBtn.classList.remove("opacity-50", "cursor-not-allowed");
                        mReadBtn.innerHTML = `Descargar Manuscrito <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>`;
                    } else {
                        mReadBtn.removeAttribute("data-pdf-url");
                        mReadBtn.classList.add("opacity-50", "cursor-not-allowed");
                        mReadBtn.textContent = "Manuscrito no disponible";
                    }
                }

                if (mDeleteBtn) {
                    if (isLogged) {
                        const currentUser = JSON.parse(userString).username;
                        if (currentUser === autor) {
                            mDeleteBtn.classList.remove("hidden");
                        } else {
                            mDeleteBtn.classList.add("hidden");
                        }
                    } else {
                        mDeleteBtn.classList.add("hidden");
                    }
                }

                if(chatMessages) chatMessages.innerHTML = '<p class="text-xs text-center text-gray-400 py-4">Cargando comentarios...</p>';

                try {
                    const res = await fetch(`/aws/api/comentarios?filters[historia][id][$eq]=${currentHistoriaId}&sort=createdAt:asc`);
                    const json = await res.json();

                    if(chatMessages) chatMessages.innerHTML = "";

                    if (json.data && json.data.length > 0) {
                        const currentUser = isLogged ? JSON.parse(userString).username : null;

                        json.data.forEach((msg) => {
                            const nombreAutor = msg.attributes?.NombreUsuario || msg.NombreUsuario || "Usuario";
                            const textoComentario = msg.attributes?.Texto || msg.Texto || "";

                            const esMio = nombreAutor === currentUser;
                            if(chatMessages) chatMessages.innerHTML += pintarMensaje(nombreAutor, textoComentario, esMio);
                        });
                    } else {
                        if(chatMessages) chatMessages.innerHTML = '<p class="text-xs text-center text-gray-400 py-4">No hay comentarios aún. ¡Sé el primero!</p>';
                    }
                    if(chatMessages) chatMessages.scrollTop = chatMessages.scrollHeight;
                } catch (error) {
                    console.error("Error cargando chat:", error);
                    if(chatMessages) chatMessages.innerHTML = '<p class="text-xs text-center text-red-400 py-4">Error al cargar los comentarios.</p>';
                }

                if(modal) {
                    modal.classList.remove("hidden");
                    document.body.style.overflow = "hidden";
                }
            });
        });

        const closeModal = () => {
            if (modal) {
                modal.classList.add("hidden");
                document.body.style.overflow = "";
            }
        };

        if (closeBtn) closeBtn.addEventListener("click", closeModal);
        if (backdrop) backdrop.addEventListener("click", closeModal);

        document.addEventListener("keydown", (e) => {
            if (e.key === "Escape") {
                closeModal();
                hideAuthModal();
            }
        });

        // --- 5. ACCIONES PROTEGIDAS DEL MODAL ---
        if (mReadBtn) {
            mReadBtn.addEventListener("click", async (e) => {
                e.preventDefault();

                if (!isLogged) {
                    showAuthModal();
                    return;
                }

                const pdfUrl = mReadBtn.getAttribute("data-pdf-url");
                const fileName = mReadBtn.getAttribute("data-filename") || "historia.pdf";
                if (!pdfUrl) return;

                const originalText = mReadBtn.innerHTML;
                mReadBtn.innerHTML = 'Descargando... <svg class="w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>';
                mReadBtn.classList.add("opacity-70", "pointer-events-none");

                try {
                    const response = await fetch(pdfUrl);
                    const blob = await response.blob();
                    const url = window.URL.createObjectURL(blob);
                    const tempLink = document.createElement("a");
                    tempLink.style.display = "none";
                    tempLink.href = url;
                    tempLink.download = fileName;
                    document.body.appendChild(tempLink);
                    tempLink.click();
                    window.URL.revokeObjectURL(url);
                    tempLink.remove();
                } catch (error) {
                    console.error("Error descargando:", error);
                    alert("No se pudo descargar el archivo.");
                } finally {
                    mReadBtn.innerHTML = originalText;
                    mReadBtn.classList.remove("opacity-70", "pointer-events-none");
                }
            });
        }

        // --- 6. ACCIÓN DE BORRAR HISTORIA ---
        if (mDeleteBtn) {
            mDeleteBtn.addEventListener("click", async () => {
                if (!isLogged) return;
                
                const confirmacion = confirm("⚠️ ¿Estás seguro de que quieres borrar esta historia para siempre? Esta acción no se puede deshacer.");
                
                if (confirmacion) {
                    const originalText = mDeleteBtn.innerHTML;
                    mDeleteBtn.innerHTML = 'Eliminando...';
                    mDeleteBtn.classList.add("opacity-50", "pointer-events-none");

                    try {
                        const res = await fetch(`/aws/api/historias/${currentHistoriaDocId}`, {
                            method: "DELETE",
                            headers: {
                                "Authorization": `Bearer ${token}`
                            }
                        });

                        if (res.ok) {
                            alert("¡Historia eliminada correctamente de la base de datos!");
                            closeModal();
                            
                            const tarjetaFantasma = document.querySelector(`.story-card[data-docid="${currentHistoriaDocId}"]`);
                            if (tarjetaFantasma) tarjetaFantasma.remove();
                            
                            const tarjetasRestantes = document.querySelectorAll('.story-card').length;
                            const storyCounter = document.getElementById("story-counter");
                            if (storyCounter) {
                                storyCounter.textContent = `${tarjetasRestantes} historia${tarjetasRestantes !== 1 ? "s" : ""} encontrada${tarjetasRestantes !== 1 ? "s" : ""}`;
                            }
                        } else {
                            const errorStrapi = await res.json();
                            alert(`Strapi dice: "${errorStrapi.error?.message || 'Error desconocido'}"`);
                        }
                    } catch (error) {
                        console.error("Error al borrar:", error);
                        alert("Error de red al intentar borrar la historia.");
                    } finally {
                        mDeleteBtn.innerHTML = originalText;
                        mDeleteBtn.classList.remove("opacity-50", "pointer-events-none");
                    }
                }
            });
        }

        // --- 7. ENVIAR CHAT A AWS ---
        const chatForm = document.getElementById("chatForm");
        const chatInput = document.getElementById("chatInput");

        if (chatInput) {
            chatInput.addEventListener("focus", (e) => {
                if (!isLogged) {
                    e.target.blur();
                    showAuthModal();
                }
            });
        }

        if (chatForm) {
            chatForm.addEventListener("submit", async (e) => {
                e.preventDefault();

                if (!isLogged) {
                    showAuthModal();
                    return;
                }

                const text = chatInput.value.trim();
                if (!text || !currentHistoriaId) return;

                const user = JSON.parse(userString);
                const botonEnvio = chatForm.querySelector("button");

                if(botonEnvio) {
                    botonEnvio.disabled = true;
                    botonEnvio.classList.add("opacity-50");
                }

                try {
                    const res = await fetch("/aws/api/comentarios", {
                        method: "POST",
                        headers: {
                            "Content-Type": "application/json",
                            Authorization: `Bearer ${token}`,
                        },
                        body: JSON.stringify({
                            data: {
                                Texto: text,
                                NombreUsuario: user.username,
                                historia: currentHistoriaId,
                            },
                        }),
                    });

                    if (res.ok) {
                        if (chatMessages && chatMessages.innerHTML.includes("No hay comentarios")) {
                            chatMessages.innerHTML = "";
                        }

                        if(chatMessages) {
                            chatMessages.insertAdjacentHTML("beforeend", pintarMensaje(user.username, text, true));
                            chatMessages.scrollTop = chatMessages.scrollHeight;
                        }
                        chatInput.value = "";
                    } else {
                        console.error("Strapi rechazó el mensaje.");
                    }
                } catch (error) {
                    console.error("Error de red enviando mensaje:", error);
                } finally {
                    if(botonEnvio) {
                        botonEnvio.disabled = false;
                        botonEnvio.classList.remove("opacity-50");
                    }
                }
            });
        }
    });
</script>