---
// src/pages/login.astro
import '../styles/global.css';

let logoUrl = "/favicon.svg"; 
try {
  // El servidor de Vercel lee directo de la IP en la construcción
  const logoResponse = await fetch('http://51.21.220.203/api/Logo?populate=*');
  const logoJson = await logoResponse.json();
  const logoPath = logoJson.data?.logo?.url || logoJson.data?.logo?.[0]?.url;
  
  // AQUÍ EL CAMBIO PARA EL NAVEGADOR: Usamos el túnel seguro
  if (logoPath) logoUrl = `/aws${logoPath}`;
} catch (error) {
  console.error("Error conectando con Strapi:", error);
}
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href={logoUrl} />
    <meta name="viewport" content="width=device-width" />
    <title>Iniciar Sesión - Folio.</title>
  </head>
  <body class="bg-gray-50 text-gray-900 font-sans antialiased min-h-screen flex flex-col">
    
    <header class="py-6 px-4 sm:px-6 lg:px-8 flex justify-center absolute w-full top-0">
      <a href="/" class="flex items-center gap-2.5 hover:opacity-80 transition">
        <div class="h-10 w-10 flex items-center justify-center overflow-hidden rounded-xl bg-white shadow-sm border border-gray-100">
          <img src={logoUrl} alt="Logo Folio" class="h-full w-full object-contain p-1" />
        </div>
        <span class="text-2xl font-extrabold tracking-tighter text-gray-950">Folio<span class="text-orange-500">.</span></span>
      </a>
    </header>

    <main class="flex-grow flex items-center justify-center px-4 pt-24 pb-12">
      <div class="bg-white w-full max-w-md p-8 sm:p-10 rounded-3xl shadow-sm border border-gray-200">
        
        <div class="text-center mb-8">
          <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">Bienvenido de nuevo</h1>
          <p class="text-gray-500 mt-2 text-sm">Inicia sesión para continuar en Folio.</p>
        </div>

        <form id="loginForm" class="flex flex-col gap-5">
          <div>
            <label class="block text-sm font-bold text-gray-700 mb-1.5">Email o Usuario</label>
            <input type="text" id="identifier" required placeholder="tu@email.com" class="w-full bg-gray-50 border border-gray-200 rounded-xl py-3 px-4 outline-none focus:ring-2 focus:ring-orange-200 focus:border-orange-500 transition shadow-inner text-sm" />
          </div>

          <div>
            <div class="flex justify-between items-center mb-1.5">
              <label class="block text-sm font-bold text-gray-700">Contraseña</label>
              <a href="#" class="text-xs font-semibold text-orange-500 hover:text-orange-600 transition">¿La olvidaste?</a>
            </div>
            <input type="password" id="password" required placeholder="••••••••" class="w-full bg-gray-50 border border-gray-200 rounded-xl py-3 px-4 outline-none focus:ring-2 focus:ring-orange-200 focus:border-orange-500 transition shadow-inner text-sm" />
          </div>

          <button type="submit" class="w-full bg-gray-900 text-white py-3.5 mt-2 rounded-full font-bold text-md hover:bg-gray-800 transition shadow-md active:scale-95">
            Iniciar sesión
          </button>
        </form>

        <p class="text-center text-sm text-gray-500 mt-8">
          ¿No tienes una cuenta? 
          <a href="/register" class="font-bold text-orange-500 hover:text-orange-600 transition">Regístrate gratis</a>
        </p>
      </div>
    </main>

  </body>
</html>

<script>
  const loginForm = document.getElementById('loginForm');
  const submitBtn = loginForm.querySelector('button[type="submit"]');

  loginForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const originalText = submitBtn.innerHTML;
    submitBtn.innerHTML = 'Iniciando sesión...';
    submitBtn.disabled = true;
    submitBtn.classList.add('opacity-70');

    const identifier = document.getElementById('identifier').value;
    const password = document.getElementById('password').value;

    try {
      // Llamamos a la API a través de nuestro proxy seguro
      const response = await fetch('/aws/api/auth/local', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          identifier: identifier,
          password: password,
        }),
      });

      // Blindaje de errores igual que en el registro
      if (!response.ok) {
        const errorText = await response.text();
        console.error("El servidor respondió con error:", errorText);
        
        try {
          const errorJson = JSON.parse(errorText);
          alert('Error al iniciar sesión: ' + (errorJson.error?.message || 'Credenciales inválidas.'));
        } catch (e) {
          alert('Error crítico de red. Revisa la consola F12.');
        }
        return;
      }

      const data = await response.json();

      // ¡Éxito! Guardamos el token y los datos del usuario
      sessionStorage.setItem('folio_token', data.jwt);
      sessionStorage.setItem('folio_user', JSON.stringify(data.user));
      
      window.location.href = '/'; 
      
    } catch (error) {
      console.error("Error de conexión:", error);
      alert('Error de conexión con el servidor. Mira la consola para más detalles.');
    } finally {
      submitBtn.innerHTML = originalText;
      submitBtn.disabled = false;
      submitBtn.classList.remove('opacity-70');
    }
  });
</script>